<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Backup Rules (v1.0.7+)
  allowBackup="false" + fullBackupContent + dataExtractionRules
  阻止 adb backup / 云备份 / 设备转移提取 Cookie / WebView storage / SharedPreferences / uniStorage
  防止 token / 用户数据泄露
-->
<full-backup-content>
    <!-- 完全排除 — 不参与自动备份 -->
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="file" path="."/>
    <exclude domain="external" path="."/>
</full-backup-content>
