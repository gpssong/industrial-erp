{
  "name": "industrial-erp-desktop",
  "version": "1.0.2",
  "description": "工业ERP桌面客户端 (Electron + Vue3)",
  "main": "src/main.js",
  "author": "ERP Team",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "29.4.6",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.industrial.erp",
    "productName": "工业ERP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/**/*",
      "pc-web-dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "工业ERP"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "x64"
        },
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business"
    },
    "extraResources": [
      {
        "from": "pc-web-dist",
        "to": "pc-web-dist"
      }
    ]
  }
}