<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.industrial.erp.modules.inventory.mapper.InvCheckDetailMapper">
    <select id="selectByCheckId" resultType="com.industrial.erp.modules.inventory.entity.InvCheckDetail">
        SELECT * FROM inv_check_detail WHERE check_id = #{id} AND deleted = 0
    </select>
</mapper>
