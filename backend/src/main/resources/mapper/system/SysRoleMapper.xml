<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.industrial.erp.modules.system.mapper.SysRoleMapper">
    <resultMap id="RoleMap" type="com.industrial.erp.modules.system.entity.SysRole">
        <id column="id" property="id"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_name" property="roleName"/>
        <result column="data_scope" property="dataScope"/>
        <result column="sort_no" property="sortNo"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectUserIdsByRoleId" resultType="Long">
        SELECT user_id FROM sys_user_role WHERE role_id = #{roleId}
    </select>

    <insert id="insertRoleMenuBatch">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES
        <foreach collection="menuIds" item="mid" separator=",">
            (#{roleId}, #{mid})
        </foreach>
    </insert>

    <delete id="deleteRoleMenus">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <insert id="insertUserRoleBatch">
        INSERT INTO sys_user_role (user_id, role_id) VALUES
        <foreach collection="userIds" item="uid" separator=",">
            (#{uid}, #{roleId})
        </foreach>
    </insert>

    <delete id="deleteUserRoles">
        DELETE FROM sys_user_role WHERE role_id = #{roleId}
    </delete>
</mapper>
