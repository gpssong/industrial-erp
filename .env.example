# ====================================================================
# 工业 ERP 环境变量样例
# 复制为 .env 后按需修改; 不要把真实 .env 提交到 git
# ====================================================================

# ---------- MySQL ----------
# 必改: 部署前改成强密码, 与下方 SPRING_DATASOURCE_PASSWORD 保持一致
MYSQL_ROOT_PASSWORD=erp_root_pwd

# ---------- 后端 Spring Boot (SPRING_DATASOURCE_*) ----------
# Docker 部署: 保持 mysql / redis 即可 (容器网络名)
# 源码部署: 改成主机 IP, 如 192.168.1.100
SPRING_DATASOURCE_HOST=mysql
SPRING_DATASOURCE_PORT=3306
SPRING_DATASOURCE_DB=industrial_erp
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=erp_root_pwd

# ---------- 后端 Redis ----------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_DATABASE=0
SPRING_DATA_REDIS_PASSWORD=

# ---------- 后端 ERP_* 自定义配置 ----------
# 上传目录 (生产建议挂载到独立卷; docker-compose.yml 已挂载到 ./data/upload)
ERP_UPLOAD_PATH=/opt/industrial-erp/upload

# 数据备份路径
ERP_BACKUP_PATH=/opt/industrial-erp/backup
ERP_BACKUP_SQL_PATH=/opt/industrial-erp/sql
ERP_BACKUP_RETENTION_DAYS=30

# mysqldump / mysql 命令路径, 留空走 $PATH
# Docker 镜像内: /usr/bin/mysqldump, /usr/bin/mysql
# macOS Homebrew: /opt/homebrew/bin/mysqldump, /opt/homebrew/bin/mysql
# Linux: /usr/bin/mysqldump, /usr/bin/mysql
ERP_MYSQLDUMP=mysqldump
ERP_MYSQL=mysql

# ---------- CORS 跨域白名单 ----------
# 逗号分隔的完整 Origin (含协议), 仅列表内的前端域名可通过浏览器调 API.
# 默认值在 application.yml (含 localhost:5173/8080 方便开发), 生产环境必须用 ERP_CORS_ALLOWED_ORIGINS 覆盖.
# 例: ERP_CORS_ALLOWED_ORIGINS=https://93gushi.com,https://erp.93gushi.com
# 注意: 不要带路径, 不要带尾斜杠; 端口非默认时必须写, 如 https://erp.93gushi.com:8443
#ERP_CORS_ALLOWED_ORIGINS=https://93gushi.com,https://www.93gushi.com

# ====================================================================
# NAS (群晖 DS918+) 部署速查
# ====================================================================
# 1. DSM 套件中心安装 Container Manager
# 2. 把项目传到 /volume1/docker/erp-system/  (含 docker-compose.yml, .env, backend/, pc-web/, sql/)
# 3. 改 MYSQL_ROOT_PASSWORD / SPRING_DATASOURCE_PASSWORD 为强密码
# 4. Container Manager -> 项目 -> 创建 -> 选 docker-compose.yml -> 构建并启动
# 5. 首次构建 5-15 分钟, 跑起来后:
#      PC 前台: http://NAS的IP
#      接口文档: http://NAS的IP:8080/api/doc.html
#      默认账号: admin / admin123
# 6. 公网访问务必走 DSM 反向代理 + HTTPS (控制面板 -> 登录门户 -> 反向代理)
# 7. Hyper Backup 备份 /volume1/docker/erp-system/ 整个目录
# 8. 详细: docs/02_部署方案.md + 群晖部署小贴士 (待补)
