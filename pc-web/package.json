{
  "name": "industrial-erp-pc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5000",
    "electron:build": "vite build && electron-builder --mac --dir",
    "electron:pack": "vite build && electron-builder --mac --dir --pd"
  },
  "build": {
    "appId": "com.industrial.erp",
    "productName": "工业ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dir",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.7",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "element-plus": "^2.6.0",
    "myprint-design": "1.0.12",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-echarts": "^6.6.9",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "sass": "^1.70.0",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.4"
  }
}
